==================================================CURRICULO
CREATE TABLE curriculos (
	id INTEGER PRIMARY KEY AUTOINCREMENT, 
	usr_id INTEGER NOT NULL, 
	nome_arquivo TEXT, 
	data_envio DATE NOT NULL, 
	caminho TEXT NOT NULL, 
	FOREIGN KEY (usr_id) REFERENCES usuarios(id)
)
-- Resulto: consulta executada com sucesso. Levou 0ms


=================================================FEEDBACK
CREATE TABLE feedbacks (
	id INTEGER PRIMARY KEY AUTOINCREMENT,
	id_recrutador INTEGER NOT NULL, 
	id_curriculo INTEGER NOT NULL, 
	comentario TEXT, 
	data_envio DATE, 
	FOREIGN KEY (id_recrutador) REFERENCES usuarios(id), 
	FOREIGN KEY (id_curriculo) REFERENCES curriculos(id)
)




